import tkinter as tk
from tkinter import messagebox
import threading
import time
def run_task(task_name, delay):
    time.sleep(delay)
    messagebox.showinfo(
        "Task Complete",
        f"Task '{task_name}' finished!"
    )
def schedule_task():
    task_name = task_entry.get()
    delay = delay_entry.get()
    if not task_name:
        messagebox.showerror(
            "Error",
            "Please enter a task name."
        )
        return
    if not delay.isdigit():
        messagebox.showerror(
            "Error",
            "Delay must be a number."
        )
        return
    delay = int(delay)
    thread = threading.Thread(
        target=run_task,
        args=(task_name, delay)
    )
    thread.start()
    messagebox.showinfo(
        "Scheduled",
        f"Task '{task_name}' scheduled in {delay} seconds."
    )
root = tk.Tk()
root.title("Task Scheduler")
root.geometry("400x250")
title_label = tk.Label(
    root,
    text="Task Scheduler App",
    font=("Arial", 16)
)
title_label.pack(pady=10)
task_entry = tk.Entry(
    root,
    width=30
)
task_entry.pack(pady=5)
delay_entry = tk.Entry(
    root,
    width=30
)
delay_entry.pack(pady=5)
schedule_button = tk.Button(
    root,
    text="Schedule Task",
    command=schedule_task
)
schedule_button.pack(pady=15)
root.mainloop()