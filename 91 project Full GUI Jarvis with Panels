import tkinter as tk
from tkinter import messagebox
import datetime
import webbrowser
def run_command():
    command = command_entry.get().strip().lower()
    if not command:
        messagebox.showwarning("Warning", "Enter a command.")
        return
    if command == "hello":
        output.insert(tk.END, "Jarvis: Hello!\n")
    elif command == "time":
        current = datetime.datetime.now().strftime("%H:%M:%S")
        output.insert(tk.END, f"Time: {current}\n")
    elif command == "date":
        today = datetime.datetime.now().strftime("%d-%m-%Y")
        output.insert(tk.END, f"Date: {today}\n")
    elif command == "open google":
        webbrowser.open("https://www.google.com")
        output.insert(tk.END, "Opening Google...\n")
    elif command == "open youtube":
        webbrowser.open("https://www.youtube.com")
        output.insert(tk.END, "Opening YouTube...\n")
    elif command == "clear":
        output.delete("1.0", tk.END)
    elif command == "exit":
        root.destroy()
    else:
        output.insert(tk.END, "Unknown Command.\n")
    command_entry.delete(0, tk.END)
root = tk.Tk()
root.title("GUI Jarvis")
root.geometry("700x500")
title = tk.Label(
    root,
    text="FULL GUI JARVIS",
    font=("Arial", 20, "bold")
)
title.pack(pady=10)
left = tk.Frame(root)
left.pack(side="left", fill="both", expand=True, padx=10)
right = tk.Frame(root)
right.pack(side="right", fill="y", padx=10)
output = tk.Text(left, height=20, width=60)
output.pack()
command_entry = tk.Entry(right, width=25)
command_entry.pack(pady=10)
run_btn = tk.Button(
    right,
    text="Run Command",
    command=run_command
)
run_btn.pack(pady=5)
commands = tk.Label(
    right,
    text="""
Commands
hello
time
date
open google
open youtube
clear
exit
"""
)
commands.pack(pady=20)
root.mainloop()