def encrypt(text, shift):
    result = ""
    for char in text:
        if char.isupper():
            result += chr((ord(char) - 65 + shift) % 26 + 65)
        elif char.islower():
            result += chr((ord(char) - 97 + shift) % 26 + 97)
        else:
            result += char
    return result
def decrypt(text, shift):
    return encrypt(text, -shift)
print(" Mini Encryption / Decryption Tool (Caesar Cipher)")
print("Type 'exit' anytime to quit\n")
while True:
    choice = input("Choose (encrypt / decrypt): ").lower()
    if choice == "exit":
        print("Goodbye! Stay secure ")
        break
    if choice not in ["encrypt", "decrypt"]:
        print("Invalid choice. Try again.\n")
        continue
    message = input("Enter your message: ")
    if message.lower() == "exit":
        print("Goodbye! Stay secure ")
        break
    shift_input = input("Enter shift number (e.g. 3): ")
    if shift_input.lower() == "exit":
        print("Goodbye! Stay secure ")
        break
    if not shift_input.isdigit():
        print("Shift must be a number.\n")
        continue
    shift = int(shift_input)
    if choice == "encrypt":
        output = encrypt(message, shift)
        print(f"Encrypted Message: {output}\n")
    else:
        output = decrypt(message, shift)
        print(f"Decrypted Message: {output}\n")