import tkinter as tk
from tkinter import messagebox
from tkinter import ttk
import time
root = tk.Tk()
root.title("Desktop Productivity Suite")
root.geometry("700x500")
tabs = ttk.Notebook(root)
tabs.pack(fill="both", expand=True)
notes_tab = tk.Frame(tabs)
tabs.add(notes_tab, text="Notes")
notes = tk.Text(notes_tab, font=("Arial", 12))
notes.pack(fill="both", expand=True)
def save_notes():
    with open("notes.txt", "w", encoding="utf-8") as file:
        file.write(notes.get("1.0", tk.END))
    messagebox.showinfo("Saved", "Notes saved.")
tk.Button(notes_tab, text="Save Notes",
          command=save_notes).pack()
todo_tab = tk.Frame(tabs)
tabs.add(todo_tab, text="Todo")
tasks = []
task_entry = tk.Entry(todo_tab, width=40)
task_entry.pack(pady=5)
task_box = tk.Listbox(todo_tab)
task_box.pack(fill="both", expand=True)
def add_task():
    task = task_entry.get()
    if task:
        tasks.append(task)
        task_box.insert(tk.END, task)
        task_entry.delete(0, tk.END)
def delete_task():
    try:
        index = task_box.curselection()[0]
        task_box.delete(index)
        tasks.pop(index)
    except:
        pass
tk.Button(todo_tab, text="Add", command=add_task).pack()
tk.Button(todo_tab, text="Delete", command=delete_task).pack()
clock_tab = tk.Frame(tabs)
tabs.add(clock_tab, text="Clock")
clock = tk.Label(clock_tab, font=("Arial", 25))
clock.pack(pady=30)
def update_clock():
    clock.config(text=time.strftime("%H:%M:%S"))
    root.after(1000, update_clock)
update_clock
calc_tab = tk.Frame(tabs)
tabs.add(calc_tab, text="Calculator")
expression = tk.Entry(calc_tab, font=("Arial", 14))
expression.pack(fill="x", padx=10, pady=10)
result = tk.Label(calc_tab, font=("Arial", 16))
result.pack()
def calculate():
    try:
        answer = eval(expression.get())
        result.config(text=str(answer))
    except:
        result.config(text="Error")
tk.Button(calc_tab,
          text="Calculate",
          command=calculate).pack()
root.mainloop()