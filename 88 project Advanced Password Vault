import os
FILE_NAME = "vault.txt"
vault = {}
def load_data():
    if os.path.exists(FILE_NAME):
        with open(FILE_NAME, "r", encoding="utf-8") as file:
            for line in file:
                account, password = line.strip().split("|")
                vault[account] = password
def save_data():
    with open(FILE_NAME, "w", encoding="utf-8") as file:
        for account, password in vault.items():
            file.write(f"{account}|{password}\n")
def add_password():
    account = input("Account Name: ").strip()
    password = input("Password: ").strip()
    if account and password:
        vault[account] = password
        save_data()
        print("Password saved.")
    else:
        print("Invalid input.")
def view_passwords():
    if not vault:
        print("Vault is empty.")
        return
    print("\n===== PASSWORD VAULT =====")
    for account in vault:
        print("-", account)
def search_password():
    account = input("Search account: ").strip()
    if account in vault:
        print("Password:", vault[account])
    else:
        print("Account not found.")
def delete_password():
    account = input("Delete account: ").strip()
    if account in vault:
        del vault[account]
        save_data()
        print("Deleted successfully.")
    else:
        print("Account not found.")
load_data()
while True:
    print("\n===== ADVANCED PASSWORD VAULT =====")
    print("1. Add Password")
    print("2. View Accounts")
    print("3. Search Password")
    print("4. Delete Password")
    print("5. Exit")
    choice = input("Choose: ")
    if choice == "1":
        add_password()
    elif choice == "2":
        view_passwords()
    elif choice == "3":
        search_password()
    elif choice == "4":
        delete_password()
    elif choice == "5":
        print("Goodbye!")
        break
    else:
        print("Invalid option.")