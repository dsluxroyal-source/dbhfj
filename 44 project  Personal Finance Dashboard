import tkinter as tk
from tkinter import messagebox
import matplotlib.pyplot as plt
expenses = {}
def add_expense():
    category = category_entry.get()
    amount = amount_entry.get()
    if category == "" or amount == "":
        messagebox.showwarning(
            "Warning",
            "Fill all fields."
        )
        return
    try:
        amount = float(amount)
        if category in expenses:
            expenses[category] += amount
        else:
            expenses[category] = amount
        messagebox.showinfo(
            "Success",
            "Expense Added!"
        )
        category_entry.delete(0, tk.END)
        amount_entry.delete(0, tk.END)
    except ValueError:
        messagebox.showerror(
            "Error",
            "Amount must be a number."
        )
def show_chart():

    if not expenses:
        messagebox.showwarning(
            "Warning",
            "No expenses available."
        )
        return
    categories = list(
        expenses.keys()
    )
    amounts = list(
        expenses.values()
    )
    plt.figure(
        figsize=(7, 5)
    )
    plt.bar(
        categories,
        amounts
    )
    plt.title(
        "Expense Dashboard"
    )
    plt.xlabel(
        "Category"
    )
    plt.ylabel(
        "Amount"
    )
    plt.show()
root = tk.Tk()
root.title(
    "Personal Finance Dashboard"
)
root.geometry(
    "400x300"
)
title_label = tk.Label(
    root,
    text="Personal Finance Dashboard",
    font=("Arial", 16)
)
title_label.pack(
    pady=15
)
category_entry = tk.Entry(
    root,
    width=30
)
category_entry.pack(
    pady=5
)
amount_entry = tk.Entry(
    root,
    width=30
)
amount_entry.pack(
    pady=5
)
add_button = tk.Button(
    root,
    text="Add Expense",
    command=add_expense
)
add_button.pack(
    pady=10
)
chart_button = tk.Button(
    root,
    text="Show Dashboard",
    command=show_chart
)
chart_button.pack(
    pady=10
)
root.mainloop()