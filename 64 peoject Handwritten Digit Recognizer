import tensorflow as tf
import numpy as np
import matplotlib.pyplot as plt
(_, _), (test_images, test_labels) = tf.keras.datasets.mnist.load_data()
test_images = test_images.astype(np.float32) / 255.0
interpreter = tf.lite.Interpreter(model_path="mnist.tflite")
interpreter.allocate_tensors()
input_details = interpreter.get_input_details()
output_details = interpreter.get_output_details()
while True:
    choice = input("Enter image index (0-9999) or 'exit': ").lower()
    if choice == "exit":
        print("Goodbye!")
        break
    try:
        index = int(choice)
        image = test_images[index]
        input_data = np.expand_dims(image, axis=(0, -1)).astype(np.float32)
        interpreter.set_tensor(
            input_details[0]["index"],
            input_data
        )
        interpreter.invoke()
        output = interpreter.get_tensor(
            output_details[0]["index"]
        )
        prediction = np.argmax(output)
        print("Predicted Digit:", prediction)
        print("Actual Digit:", test_labels[index])
        plt.imshow(image, cmap="gray")
        plt.title(f"Prediction: {prediction}")
        plt.axis("off")
        plt.show()
    except Exception as e:
        print("Error:", e)