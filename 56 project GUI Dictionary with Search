import tkinter as tk
from tkinter import messagebox
dictionary = {
    "python": "A programming language.",
    "variable": "A container used to store data.",
    "function": "A reusable block of code.",
    "loop": "Repeats a block of code.",
    "list": "A collection of multiple items.",
    "dictionary": "Stores data in key-value pairs.",
    "tuple": "An ordered, immutable collection.",
    "string": "A sequence of characters.",
    "integer": "A whole number.",
    "boolean": "A value that is either True or False."
}
def search_word():
    word = word_entry.get().strip().lower()
    if not word:
        messagebox.showwarning("Warning", "Please enter a word.")
        return
    if word in dictionary:
        result_label.config(text=f"Meaning:\n{dictionary[word]}")
    else:
        result_label.config(text="Word not found.")
root = tk.Tk()
root.title("GUI Dictionary")
root.geometry("400x300")
title_label = tk.Label(root, text="Dictionary Search", font=("Arial", 16))
title_label.pack(pady=10)
word_entry = tk.Entry(root, width=30)
word_entry.pack(pady=5)
search_button = tk.Button(root, text="Search", command=search_word)
search_button.pack(pady=10)
result_label = tk.Label(root, text="", wraplength=350, justify="left", font=("Arial", 12))
result_label.pack(pady=20)
root.mainloop()